# Copy to .config/skill-evals.env and fill in local values.
# .config/skill-evals.env is ignored by git.

# Required for live golden evals against the target agent/model proxy.
SKILL_EVAL_MODEL=
OPENAI_API_KEY=

# Optional semantic judge. Defaults to SKILL_EVAL_MODEL when unset.
# Use a stronger model here than SKILL_EVAL_MODEL when judging nuanced criteria.
# SKILL_EVAL_JUDGE_MODEL=gpt-5.5

# Optional clarity stress test. CI treats this model as non-blocking.
# SKILL_EVAL_STRESS_MODEL=

# Optional for OpenAI-compatible APIs.
# SKILL_EVAL_API_BASE=https://api.openai.com/v1
